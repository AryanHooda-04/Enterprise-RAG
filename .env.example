OPENAI_API_KEY=replace-with-your-key

# OpenAI models
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_CHAT_MODEL=gpt-5.2
OPENAI_VISION_MODEL=gpt-4.1-mini
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=marin
OPENAI_TEMPERATURE=0

# SSL modes:
# - system: use OS trust store, best default for corporate Windows laptops
# - custom: use OPENAI_CA_BUNDLE / SSL_CERT_FILE / REQUESTS_CA_BUNDLE
# - certifi: use certifi.where()
# - insecure: disable verification only if your local security policy permits it
OPENAI_SSL_MODE=system

# RAG defaults
CHUNK_SIZE_TOKENS=500
CHUNK_OVERLAP_TOKENS=50
TOP_K=5
MAX_ANSWER_TOKENS=800
MAX_UPLOAD_FILES=20
MAX_UPLOAD_SIZE_MB=4096
HYBRID_SEMANTIC_WEIGHT=0.7
VISION_INGESTION_ENABLED=true
VISION_DETAIL=high
MAX_VISUAL_PAGES=80
MAX_DOCX_IMAGES=80
MAX_IMAGE_DIMENSION_PX=1600
VOICE_OUTPUT_ENABLED=true
VOICE_LANGUAGE=Auto

# Public Streamlit demo guardrails.
# Keep enabled when the deployed app uses your API key.
RAG_DEMO_LIMITS_ENABLED=true
RAG_DEMO_DAILY_CALL_LIMIT=80
RAG_DEMO_DAILY_TOKEN_LIMIT=200000
RAG_DEMO_SESSION_CALL_LIMIT=12
RAG_DEMO_MAX_UPLOAD_FILES=3
RAG_DEMO_MAX_UPLOAD_SIZE_MB=10
RAG_DEMO_MAX_TOP_K=5
RAG_DEMO_MAX_EVALUATION_CASES=5
RAG_DEMO_MAX_VISUAL_PAGES=5
RAG_DEMO_MAX_DOCX_IMAGES=5

# Local UI/API RBAC.
RAG_AUTH_ENABLED=true
RAG_DEFAULT_ROLE=User
RAG_ADMIN_USERNAME=admin
RAG_ADMIN_PASSWORD=admin
RAG_USER_USERNAME=user
RAG_USER_PASSWORD=user

# Local storage
RAG_DATA_DIR=data

# Corporate SSL / proxy environments
# Prefer pointing this at your corporate CA bundle when certificate validation fails.
# OPENAI_CA_BUNDLE=C:\path\to\company-ca-bundle.pem
OPENAI_VERIFY_SSL=true
DISABLE_SSL_WARNINGS=false

# Last-resort fallback requested for restrictive environments.
# Keep false unless your local security policy permits disabling bundle env vars.
RAG_EMPTY_CA_BUNDLE_FALLBACK=false
